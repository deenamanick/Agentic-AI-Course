LLM_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# SAFETY FIRST! Set this to true to prevent accidentally spamming real emails while testing
MOCK_EMAILS=true

# If you set MOCK_EMAILS=false, you must provide these:
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Langfuse (optional but recommended for tracing agent reasoning)
LANGFUSE_PUBLIC_KEY=pk-your-key
LANGFUSE_SECRET_KEY=sk-your-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

APP_PROJECT=Jeevi-Academy
APP_ENV=Development
FRONTEND_ORIGIN=http://localhost:5173
